{
    "name": "@omni-oss/set-version",
    "description": "Sets version of various package manifests",
    "version": "0.2.0",
    "bin": "./dist/set-version.mjs",
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": {
                "development": "./src/index.ts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "development": "./src/index.ts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "dependencies": {
        "zod": "catalog:",
        "commander": "catalog:",
        "@commander-js/extra-typings": "catalog:",
        "@omni-oss/system-interface": "workspace:^",
        "fast-xml-parser": "^5.8.0",
        "@nodable/compact-builder": "^1.0.8",
        "fast-xml-builder": "^1.2.0",
        "yaml": "^2.8.3",
        "comment-json": "^5.0.0",
        "smol-toml": "^1.6.1",
        "picomatch": "^4.0.4"
    },
    "devDependencies": {
        "@omni-oss/tsconfig": "catalog:",
        "@omni-oss/vite-config": "catalog:",
        "@omni-oss/vitest-config": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:",
        "@types/node": "catalog:",
        "@types/bun": "catalog:",
        "@types/picomatch": "^4.0.3",
        "typescript": "catalog:"
    }
}
