{
    "name": "@omni-oss/system-interface",
    "version": "0.1.2",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": {
                "development": "./src/index.ts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "development": "./src/index.ts",
                "default": "./dist/index.mjs"
            }
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": {
                "development": "./src/*.ts",
                "default": "./dist/*.mjs"
            },
            "require": {
                "development": "./src/*.ts",
                "default": "./dist/*.mjs"
            }
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "memfs": "^4.57.2"
    },
    "devDependencies": {
        "@omni-oss/tsconfig": "catalog:",
        "@omni-oss/vite-config": "catalog:",
        "@omni-oss/vitest-config": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:",
        "typescript": "catalog:",
        "@types/node": "catalog:",
        "@types/bun": "catalog:",
        "@types/deno": "^2.5.0"
    }
}
