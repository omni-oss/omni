{
    "name": "@omni-oss/bridge-rpc-services",
    "description": "A TypeScript Package",
    "version": "0.0.0-semantically-released",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": {
                "development": "./src/index.ts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "development": "./src/index.ts",
                "default": "./dist/index.mjs"
            }
        },
        "./*": {
            "types": "./dist/*/index.d.ts",
            "import": {
                "development": "./src/*/index.ts",
                "default": "./dist/*.mjs"
            },
            "require": {
                "development": "./src/*/index.ts",
                "default": "./dist/*.mjs"
            }
        }
    },
    "dependencies": {
        "zod": "catalog:"
    },
    "peerDependencies": {
        "@omni-oss/bridge-rpc-core": "workspace:^",
        "@omni-oss/runtime-utils": "workspace:^",
        "@omni-oss/system-interface": "workspace:^",
        "@omni-oss/channels": "workspace:^",
        "@omni-oss/bridge-rpc-utils": "workspace:^",
        "@omni-oss/async-utils": "workspace:^",
        "@omni-oss/log": "workspace:^",
        "@omni-oss/bridge-rpc-system-interface": "workspace:^",
        "@omni-oss/gen-sdk-core": "workspace:^"
    },
    "devDependencies": {
        "@omni-oss/channels": "workspace:^",
        "@omni-oss/gen-sdk-core": "workspace:^",
        "@omni-oss/tsconfig": "workspace:^",
        "@omni-oss/vite-config": "workspace:^",
        "@omni-oss/vitest-config": "workspace:^",
        "@types/node": "catalog:",
        "@types/bun": "catalog:",
        "@types/deno": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:",
        "typescript": "catalog:"
    }
}
